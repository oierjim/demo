</logger>


<logger name="n38i">
        <level value="DEBUG" />
        <appender-ref ref="logs_n38a" />
</logger>

<logger name="n38c">
        <level value="DEBUG" />
        <appender-ref ref="logs_n38a" />
</logger>

<logger name="n38n">
        <level value="DEBUG" />
        <appender-ref ref="logs_n38a" />
</logger>

</log4j:configuration>

